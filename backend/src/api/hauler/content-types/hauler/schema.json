{
  "kind": "collectionType",
  "collectionName": "haulers",
  "info": {
    "singularName": "hauler",
    "pluralName": "haulers",
    "displayName": "Hauler",
    "description": "Bulk water hauling company listing"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "phone": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "website": {
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "city": {
      "type": "string"
    },
    "state": {
      "type": "string"
    },
    "zip": {
      "type": "string"
    },
    "serviceArea": {
      "type": "text"
    },
    "minFee": {
      "type": "decimal"
    },
    "truckCapacity": {
      "type": "integer"
    },
    "hoseLength": {
      "type": "integer"
    },
    "waterType": {
      "type": "enumeration",
      "enum": ["potable", "non-potable", "both"]
    },
    "isVerifiedPro": {
      "type": "boolean",
      "default": false
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "isClaimed": {
      "type": "boolean",
      "default": false
    },
    "services": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::service.service",
      "mappedBy": "hauler"
    },
    "caseStudies": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::case-study.case-study",
      "mappedBy": "hauler"
    },
    "industries": {
      "type": "json"
    },
    "certification": {
      "type": "string"
    },
    "truckCount": {
      "type": "integer"
    },
    "pumpType": {
      "type": "string"
    },
    "hoseMaterial": {
      "type": "string"
    },
    "yearsInBusiness": {
      "type": "integer"
    },
    "serviceRadius": {
      "type": "integer"
    },
    "insuranceCertificate": {
      "type": "string"
    },
    "ada": {
      "type": "boolean",
      "default": false
    },
    "lgbtqFriendly": {
      "type": "boolean",
      "default": false
    },
    "veteranOwned": {
      "type": "boolean",
      "default": false
    },
    "womenOwned": {
      "type": "boolean",
      "default": false
    },
    "hours": {
      "type": "string"
    },
    "plusCode": {
      "type": "string"
    }
  }
