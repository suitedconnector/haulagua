{
  "kind": "collectionType",
  "collectionName": "locations",
  "info": {
    "singularName": "location",
    "pluralName": "locations",
    "displayName": "Location",
    "description": "SEO landing page data for a city/state"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "city": {
      "type": "string",
      "required": true
    },
    "state": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "required": true
    },
    "metaTitle": {
      "type": "string"
    },
    "metaDescription": {
      "type": "text"
    },
    "introShort": {
      "type": "text"
    },
    "introLong": {
      "type": "richtext"
    },
    "localContext": {
      "type": "richtext"
    },
    "availableServices": {
      "type": "json"
    },
    "faqs": {
      "type": "json"
    },
    "nearbyCities": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::location.location",
      "inversedBy": "nearbyCities"
    }
  }
}